{
  "name": "phonara-gb",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter @phonara/web dev",
    "dev:web": "bun --filter @phonara/web dev",
    "dev:admin": "bun --filter @phonara/admin dev",
    "build": "bun run build:packages && bun run build:apps",
    "build:apps": "bun --filter @phonara/web build && bun --filter @phonara/admin build",
    "build:packages": "bun --filter './packages/*' build",
    "typecheck": "tsc -b tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "check": "bun run check:env && bun run check:i18n && bun run typecheck && bun run lint && bun run test && bun run build",
    "check:env": "tsx scripts/check-env.ts",
    "check:i18n": "tsx scripts/check-i18n-coverage.ts",
    "clean": "bun run clean:artifacts",
    "clean:artifacts": "tsx scripts/clean-artifacts.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.0",
    "@tanstack/react-router": "^1.170.15",
    "clsx": "^2.1.1",
    "decimal.js": "^10.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  }
}
