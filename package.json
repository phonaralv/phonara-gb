{
  "name": "phonara-gb",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter @phonara/web dev",
    "dev:web": "bun --filter @phonara/web dev",
    "dev:admin": "bun --filter @phonara/admin dev",
    "build": "bun run build:packages && bun run build:apps",
    "build:apps": "bun --filter @phonara/web build && bun --filter @phonara/admin build",
    "build:packages": "bun --filter './packages/*' build",
    "typecheck": "tsc -b --force tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:sql": "tsx scripts/run-sql-tests.ts",
    "test:e2e": "playwright test",
    "check": "bun run check:env && bun run check:i18n && bun run check:release && bun run check:advisors && bun run check:deps && bun run typecheck && bun run lint && bun run test && bun run build",
    "check:env": "tsx scripts/check-env.ts",
    "check:i18n": "tsx scripts/check-i18n-coverage.ts",
    "check:deps": "knip --dependencies --no-progress --workspace \"@phonara/*\"",
    "check:pwa": "tsx scripts/check-pwa.ts",
    "check:release": "tsx scripts/check-release.ts",
    "check:advisors": "tsx scripts/check-advisors.ts",
    "clean": "bun run clean:artifacts",
    "clean:artifacts": "tsx scripts/clean-artifacts.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "fast-check": "^4.8.0",
    "globals": "^17.6.0",
    "knip": "^6.16.1",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "decimal.js": "^10.6.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  }
}
